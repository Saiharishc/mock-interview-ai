# Backend environment configuration
APP_NAME=mock-interview-ai
ENVIRONMENT=development

# Cryptography master key for Fernet (generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
MASTER_KEY=replace-me-with-a-real-fernet-key

# JWT signing
JWT_SECRET=replace-me-with-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MIN=60

# Database
DATABASE_URL=sqlite:///./mock_interview.db

# Google OAuth (create credentials at https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cost guardrails
PER_SESSION_INPUT_TOKEN_CAP=30000
PER_USER_DAILY_CALL_LIMIT=500
