<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: "Helvetica Neue", Helvetica, Arial, sans-serif; color: #1a1a2e; font-size: 13px; line-height: 1.5; padding: 40px 48px; }
    h1 { font-size: 22px; font-weight: 700; color: #1a1a2e; margin-bottom: 4px; }
    .subtitle { color: #6b7280; margin-bottom: 32px; }
    h2 { font-size: 15px; font-weight: 600; color: #1a1a2e; margin: 24px 0 10px; border-bottom: 1px solid #e5e7eb; padding-bottom: 4px; }
    .score-badge { display: inline-block; background: #2563eb; color: #fff; font-size: 28px; font-weight: 700; padding: 10px 24px; border-radius: 12px; margin-bottom: 20px; }
    .tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .tag { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; padding: 3px 10px; border-radius: 99px; font-size: 12px; }
    .tag.bad { background: #fef2f2; color: #dc2626; border-color: #fecaca; }
    .tag.study { background: #f0fdf4; color: #15803d; border-color: #bbf7d0; }
    table { width: 100%; border-collapse: collapse; margin-top: 8px; }
    th, td { text-align: left; padding: 6px 10px; border-bottom: 1px solid #e5e7eb; font-size: 12px; }
    th { background: #f9fafb; font-weight: 600; }
    .bar-wrap { background: #e5e7eb; border-radius: 4px; height: 8px; width: 120px; overflow: hidden; }
    .bar { background: #2563eb; height: 8px; border-radius: 4px; }
    .summary { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 8px; padding: 14px 18px; margin-top: 8px; color: #1e40af; }
    .q-block { margin-bottom: 18px; padding: 12px 14px; border: 1px solid #e5e7eb; border-radius: 8px; }
    .q-block .q { font-weight: 600; margin-bottom: 6px; }
    .q-block .a { color: #374151; }
    .q-block .fb { margin-top: 8px; font-size: 12px; color: #6b7280; }
    .footer { margin-top: 40px; text-align: center; font-size: 11px; color: #9ca3af; }
  </style>
</head>
<body>
  <h1>Mock Interview Report</h1>
  <p class="subtitle">Role: {{ session.role }} &middot; {{ session.difficulty|capitalize }} &middot; {{ session.interview_type.replace("_", " ")|title }} &middot; {{ session.created_at.strftime("%Y-%m-%d") }}</p>

  <h2>Overall Score</h2>
  <div class="score-badge">{{ "%.1f"|format(summary.overall_score) }} / 10</div>
  <p class="summary">{{ summary.summary }}</p>

  <h2>Topic Breakdown</h2>
  <table>
    <tr><th>Topic</th><th>Score</th><th></th></tr>
    {% for topic, score in summary.topic_scores.items() %}
    <tr>
      <td>{{ topic }}</td>
      <td>{{ "%.1f"|format(score) }}/10</td>
      <td><div class="bar-wrap"><div class="bar" style="width:{{ (score/10*100)|int }}%"></div></div></td>
    </tr>
    {% endfor %}
  </table>

  <h2>Strong Areas</h2>
  <div class="tags">
    {% for a in summary.strong_areas %}<span class="tag">{{ a }}</span>{% endfor %}
  </div>

  <h2>Weak Areas</h2>
  <div class="tags">
    {% for a in summary.weak_areas %}<span class="tag bad">{{ a }}</span>{% endfor %}
  </div>

  <h2>Recommended Study Topics</h2>
  <div class="tags">
    {% for t in summary.recommended_topics %}<span class="tag study">{{ t }}</span>{% endfor %}
  </div>

  <h2>Suggestions for Improvement</h2>
  <ul style="padding-left:18px;margin-top:8px;">
    {% for s in summary.suggestions %}<li style="margin-bottom:4px;">{{ s }}</li>{% endfor %}
  </ul>

  {% if transcript %}
  <h2>Full Transcript</h2>
  {% for entry in transcript %}
  <div class="q-block">
    <div class="q">Q{{ entry.order }}: {{ entry.question }}</div>
    <div class="a">{{ entry.answer or "(no answer recorded)" }}</div>
    {% if entry.score is not none %}
    <div class="fb">Score: {{ "%.1f"|format(entry.score) }}/10{% if entry.feedback %} &mdash; {{ entry.feedback.good }}{% endif %}</div>
    {% endif %}
  </div>
  {% endfor %}
  {% endif %}

  <div class="footer">Generated by Mock Interview AI &middot; {{ now }}</div>
</body>
</html>
